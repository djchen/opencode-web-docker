{
  "name": "opencode-web-docker",
  "description": "OpenCode Web Docker",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "repository": {
    "type": "git",
    "url": "https://github.com/djchen/opencode-web-docker.git"
  },
  "homepage": "https://github.com/djchen/opencode-web-docker",
  "bugs": {
    "url": "https://github.com/djchen/opencode-web-docker/issues"
  },
  "scripts": {
    "test:build-compat": "bun test tests",
    "typecheck": "tsc --noEmit",
    "build:runtime": "bun run build/transpile-runtime.ts",
    "lint": "oxlint build runtime tests scripts",
    "docker:build": "docker build -t opencode-web-docker .",
    "upstream:update": "./scripts/update-opencode-release.sh",
    "format": "prettier --write \"build/**/*.ts\" \"runtime/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"build/**/*.ts\" \"runtime/**/*.ts\" \"tests/**/*.ts\""
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.0",
    "@types/bun": "1.3.13",
    "oxlint": "^1.61.0",
    "prettier": "3.6.2",
    "typescript": "5.8.x"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120
  }
}